# =============================================================================
# HoneyFlow 배포용 환경변수 설정 예시
# 사용법: cp env.deploy.example .env
# =============================================================================

# =============================================================================
# 애플리케이션 기본 설정
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# MySQL 데이터베이스 설정
# =============================================================================
MYSQL_HOST=mysql-container
MYSQL_PORT=3306
MYSQL_USER=honeyflow
MYSQL_PASSWORD=honeyflow
MYSQL_DATABASE=honeyflow_prod
MYSQL_ROOT_PASSWORD=honeyflow

# =============================================================================
# MongoDB 설정
# =============================================================================
MONGO_HOST=mongodb-container
MONGO_USER=honey
MONGO_PASSWORD=honeyflow
MONGO_DB=honeyflow_prod

# =============================================================================
# Redis 설정
# =============================================================================
REDIS_HOST=redis-container
REDIS_PORT=6379
REDIS_USERNAME=honeyflow
REDIS_PASSWORD=honeyflow

# =============================================================================
# 웹소켓 서버 설정 (Collaborative Service)
# =============================================================================
SERVER_ID=room1-server
WS_PORT=9001

# =============================================================================
# 로드밸런서 설정
# =============================================================================
PORT=4242

# =============================================================================
# SSL 및 도메인 설정 (선택사항)
# =============================================================================
# DOMAIN_NAME=your-domain.com
# SSL_EMAIL=your-email@domain.com