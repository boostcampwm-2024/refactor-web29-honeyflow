# =============================================================================
# HoneyFlow 배포용 환경변수 설정 예시
# 사용법: cp env.deploy.example .env
# =============================================================================

# 애플리케이션 설정
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# 외부 데이터베이스 서비스 설정 (권장)
# =============================================================================

# MySQL 설정 (AWS RDS 또는 외부 MySQL 서비스)
MYSQL_HOST=your-rds-endpoint.region.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=honeyflow
MYSQL_PASSWORD=your-secure-mysql-password
MYSQL_DATABASE=honeyflow_prod

# MongoDB 설정 (MongoDB Atlas 또는 외부 MongoDB 서비스)
MONGO_HOST=cluster0.xxxxx.mongodb.net
MONGO_USER=honeyflow
MONGO_PASSWORD=your-secure-mongo-password
MONGO_DB=honeyflow_prod

# Redis 설정 (AWS ElastiCache 또는 외부 Redis 서비스)
REDIS_HOST=your-redis-endpoint.region.cache.amazonaws.com
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your-secure-redis-password

# =============================================================================
# SSL 및 도메인 설정
# =============================================================================

# 도메인 설정 (SSL 인증서용)
DOMAIN_NAME=your-domain.com
SSL_EMAIL=your-email@domain.com

# =============================================================================
# 보안 설정
# =============================================================================

# JWT 시크릿 (랜덤 문자열로 변경 필요)
JWT_SECRET=your-super-secure-jwt-secret-key-change-this

# API 키 (외부 서비스 연동용)
API_SECRET_KEY=your-api-secret-key

# =============================================================================
# 배포 정보
# =============================================================================

# 배포 환경 정보
DEPLOY_VERSION=v1.0.0
DEPLOY_TIMESTAMP=20241201120000
DEPLOY_BRANCH=main 